Unit]
Description=Quiz Application (Node.js)
Documentation=https://github.com/josephDelnordd/ansible-role-quiz-app
After=network.target

[Service]
Type=simple
User={{ app_user }}
WorkingDirectory={{ app_home }}
Environment="NODE_ENV=production"
ExecStart=/usr/local/bin/serve -s {{ app_home }}/dist -l {{ app_port }}
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal
SyslogIdentifier=quiz-app

# Security settings
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=yes
ReadWritePaths={{ app_home }}

[Install]
WantedBy=multi-user.target